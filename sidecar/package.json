{
  "name": "rover-sidecar",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "e2e:local-round": "tsx src/e2e-local-round.ts",
    "e2e:dev-join": "tsx src/e2e-dev-join.ts",
    "e2e:cancel": "tsx src/e2e-cancel.ts",
    "e2e:stake-adapter": "tsx src/e2e-stake-adapter.ts",
    "e2e:operator-settle-winner": "tsx src/e2e-operator-settle-winner.ts",
    "e2e:harness-bridge": "tsx src/e2e-harness-bridge.ts",
    "e2e:manual-pilot-ui": "tsx src/e2e-manual-pilot-ui.ts",
    "e2e:manual-pilot-webrtc": "tsx src/e2e-manual-pilot-webrtc.ts",
    "e2e:signer-x402": "tsx src/e2e-signer-x402.ts",
    "e2e:apriltag-finish-spike": "tsx src/e2e-apriltag-finish-spike.ts",
    "e2e:field-sim": "tsx src/e2e-field-sim.ts",
    "e2e:sensor-replay": "tsx src/e2e-sensor-replay.ts",
    "bridge:harness": "tsx src/harness-bridge.ts",
    "sim:robot": "tsx src/sim-robot.ts",
    "replay:sensors": "tsx src/sensor-replay.ts",
    "sim:finish": "tsx src/sim-finish-detector.ts",
    "spike:apriltag-finish": "tsx src/apriltag-finish-spike.ts",
    "detector:lidar": "tsx src/lidar-finish-detector.ts",
    "build:ledger": "esbuild web-src/ledger.ts --bundle --format=esm --outfile=public/ledger.bundle.js --platform=browser --define:global=globalThis",
    "build:pilot": "npm run build:pilot:legacy && npm run build:pilot:react",
    "build:pilot:legacy": "esbuild web-src/pilot-app.ts --bundle --format=esm --outfile=public/pilot-app.bundle.js --platform=browser --define:global=globalThis",
    "build:pilot:react": "esbuild web-src/pilot-react.tsx --bundle --format=esm --outfile=public/pilot-react.bundle.js --platform=browser --jsx=automatic --define:global=globalThis"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
    "@ensdomains/ensjs": "^4.2.3",
    "@google-cloud/bigquery": "^7.9.0",
    "@ledgerhq/context-module": "^2.1.0",
    "@ledgerhq/device-management-kit": "^1.6.0",
    "@ledgerhq/device-signer-kit-ethereum": "^1.16.0",
    "@ledgerhq/device-transport-kit-web-hid": "^1.2.3",
    "@ledgerhq/device-transport-kit-web-ble": "^1.2.3",
    "@privy-io/node": "latest",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "express": "^4.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "viem": "^2.21.0",
    "werift": "^0.23.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
