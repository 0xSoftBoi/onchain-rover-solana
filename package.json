{
  "name": "onchain-rover",
  "private": true,
  "type": "module",
  "scripts": {
    "chain:compile": "npm --prefix chain run compile",
    "chain:test": "npm --prefix chain run test",
    "chain:node": "npm --prefix chain run node",
    "chain:deploy": "npm --prefix chain run deploy",
    "chain:export": "npm --prefix chain run export",
    "compose:up": "docker compose up --detach --wait",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f chain sidecar",
    "compose:ps": "docker compose ps",
    "e2e:local-race": "bash scripts/e2e-local-race.sh",
    "e2e:sidecar-round": "npm --prefix sidecar run e2e:local-round",
    "e2e:dev-join": "npm --prefix sidecar run e2e:dev-join",
    "e2e:harness-bridge": "npm --prefix sidecar run e2e:harness-bridge",
    "e2e:field-sim": "npm --prefix sidecar run e2e:field-sim",
    "robot:deploy-check": "cargo run --manifest-path robot-harness/Cargo.toml --bin rover-deploy-check --",
    "robot:stage-deployer": "echo 'stage deployer GUI disabled; use robot-harness/deploy/reset-jetson-over-ssh.sh'"
  }
}
