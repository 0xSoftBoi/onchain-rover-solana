# Copy or pass with: docker compose --env-file .env.compose up --wait
#
# The COMPOSE_* names intentionally avoid stale values from the root .env used
# by ad-hoc local processes.

COMPOSE_CHAIN_PORT=8545
COMPOSE_SIDECAR_PORT=4021
COMPOSE_PUBLIC_LOCAL_CHAIN_RPC_URL=http://127.0.0.1:8545
COMPOSE_PUBLIC_SIDECAR_URL=http://127.0.0.1:4021

# Stage robot URLs. Override these if DHCP changes.
COMPOSE_GUARD_URL=http://172.16.2.151:8000
COMPOSE_COURIER_URL=http://192.168.0.192:8000

# Public/Arc-safe defaults. Set these to 1 only for local rehearsals.
COMPOSE_ALLOW_FREE_PILOT=0
COMPOSE_ALLOW_ROUND_PILOT=1
COMPOSE_ALLOW_SHOW_RACE_AUTOSTART=1
COMPOSE_SHOW_FINISH_ODOMETRY_M=2.0
COMPOSE_ALLOW_LOCAL_DEV_WALLETS=0

# x402 seller address. Replace with the real Arc testnet fleet treasury address
# before collecting public payments.
COMPOSE_TREASURY_ADDRESS=0x08581b71bAab3781A1ca3f41E9d86aa681792c3C

# Deterministic Hardhat local-chain keys. These are public test keys only.
COMPOSE_LOCAL_FACILITATOR_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6
COMPOSE_LOCAL_TOKEN_OWNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
