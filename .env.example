# ---- robots (travel-router LAN) ----
GUARD_URL=http://192.168.8.71:8000
COURIER_URL=http://192.168.8.72:8000
GUARD_WALLET=
COURIER_WALLET=
GUARD_PRIVY_WALLET_ID=
COURIER_PRIVY_WALLET_ID=
GUARD_AGENT_ID=
COURIER_AGENT_ID=
FLEET_FROM_BLOCK=            # Sepolia block at first registration tonight

# ---- sidecar ----
PORT=4021
TREASURY_ADDRESS=            # fleet treasury (Ledger-governed operator)
REQUESTER_PRIVATE_KEY=       # rates the robots (must NOT own the agents)
ALLOW_FREE_PILOT=1           # local harness only: sidecar bridge pilot sessions

# ---- local Hardhat race harness ----
LOCAL_CHAIN_RPC_URL=http://127.0.0.1:8545
PUBLIC_LOCAL_CHAIN_RPC_URL=http://<laptop-ip>:8545
PUBLIC_SIDECAR_URL=http://<laptop-ip>:4021
LOCAL_CHAIN_ID=31337
RACE_TOKEN_ADDRESS=
RACE_ESCROW_ADDRESS=
LOCAL_TREASURY_ADDRESS=
LOCAL_FACILITATOR_PRIVATE_KEY=
LOCAL_TOKEN_OWNER_PRIVATE_KEY=
LOCAL_RACE_AUTH_TTL_SECS=3600
RACE_NETWORK_FEE_USDC=0.25

# ---- Solana settlement backend (Clanker 5000 — see docs/SOLANA_PORT.md) ----
CHAIN_BACKEND=evm            # set to "solana" to route settlement through the Anchor program
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_PROGRAM_ID=           # clanker5000 program id (after `anchor keys sync`)
SOLANA_USDC_MINT=            # SPL mint used as USDC (local mint or devnet USDC)
FACILITATOR_SECRET_KEY=      # base58/JSON keypair for lifecycle txs (facilitator)
SOLANA_DEV_KEYS_DIR=         # local dev only: dir of <pubkey>.json driver keypairs for join_race
SOLANA_MINT_AUTHORITY_SECRET_KEY=  # local faucet mint authority (fundLocalWallet)
# SNS identity (Solana-native ENS) — see docs/SOLANA_PORT.md
SNS_RPC_URL=https://api.mainnet-beta.solana.com
SNS_PARENT_LABEL=roverfleet  # resolves guard.roverfleet.sol / courier.roverfleet.sol
# x402 on Solana: when CHAIN_BACKEND=solana the paid routes (/task, /pilot, race
# join) verify SPL-USDC payments to TREASURY_ADDRESS (a USDC token account).
# Pay by sending the X-PAYMENT header = base64({"transaction":"<sig>"}).

# ---- ClawPump (agent token launchpad on Solana / pump.fun) ----
CLAWPUMP_API_URL=https://clawpump.tech/api
CLAWPUMP_API_KEY=            # agent key from the ClawPump dashboard (login-walled)
CLAWPUMP_AGENT_ID=           # your registered ClawPump agent id
CLAWPUMP_DEFAULT_IMAGE=      # optional image URL for launched tokens

# ---- sponsor keys (collect Phase 0) ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NAMESTONE_API_KEY=
ENS_PARENT=roverfleet.eth
GEMINI_API_KEY=
WORLD_RP_ID=                 # rp_... (NOT app_...)
WORLD_SIGNING_KEY=
NEXT_PUBLIC_WORLD_APP_ID=    # app_...
DYNAMIC_ENVIRONMENT_ID=
# GCP: gcloud auth application-default login (no key needed)

# ---- robot-side (set on each Jetson) ----
ROBOT_ROLE=guard             # or courier
PEER_ROBOT_URL=              # the other robot's http://...:8000
SIDECAR_URL=ws://<laptop-ip>:4021
GEOFENCE_ODO=4000
# GIBBER_NETWORK_ONLY=1      # uncomment if venue noise kills audio
