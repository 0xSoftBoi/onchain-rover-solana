# Native-Solana-only fork — see docs/SOLANA_NATIVE_MIGRATION.md.
# (The hybrid/EVM env lives in the sibling repo.) All settlement runs through the
# clanker5000 Anchor program; there is no EVM/Arc/Hardhat config here.

# ---- robots (travel-router LAN) ----
# A robot can be a Jetson harness OR a real FrodoBots Earth Rover: point its URL
# at the Earth Rovers adapter, e.g. GUARD_URL=http://127.0.0.1:4021/earthrover
GUARD_URL=http://192.168.8.71:8000
COURIER_URL=http://192.168.8.72:8000

# ---- Earth Rovers SDK (drive a real FrodoBots rover) — see docs/EARTH_ROVERS.md ----
EARTH_ROVER_URL=http://127.0.0.1:8000   # where the Earth Rovers SDK (Python) runs
# SDK_API_TOKEN + BOT_SLUG go in the Earth Rovers SDK's OWN .env, not here.
GUARD_WALLET=                # guard robot base58 Solana pubkey
COURIER_WALLET=              # courier robot base58 Solana pubkey
GUARD_AGENT_ID=0
COURIER_AGENT_ID=1
GUARD_SNS=                   # optional override (default guard.<SNS_PARENT>.sol)
COURIER_SNS=                 # optional override (default courier.<SNS_PARENT>.sol)

# ---- sidecar ----
PORT=4021
PUBLIC_SIDECAR_URL=http://<laptop-ip>:4021
ALLOW_FREE_PILOT=1           # local harness only: sidecar bridge pilot sessions
RACE_NETWORK_FEE_USDC=0.25

# ---- Solana settlement (clanker5000 Anchor program) ----
CHAIN_BACKEND=solana         # native-Solana fork: solana is the only backend
# Helius (free tier): if set, used as the BACKEND rpc (keyed, server-only — never
# exposed to clients). Enables getPriorityFeeEstimate + DAS. See docs/HELIUS.md.
HELIUS_API_KEY=
SOLANA_RPC_URL=              # explicit override; leave blank to use Helius (if key) or default
SOLANA_RPC_URL_FALLBACK=http://127.0.0.1:8899
PUBLIC_SOLANA_RPC_URL=http://<laptop-ip>:8899
SOLANA_PROGRAM_ID=           # clanker5000 program id (after `anchor keys sync`)
SOLANA_USDC_MINT=            # SPL mint used as USDC (local mint or devnet USDC)
TREASURY_ADDRESS=            # treasury USDC token account (x402 paid-route payee)
FACILITATOR_SECRET_KEY=      # base58/JSON keypair for lifecycle txs (facilitator)
SOLANA_DEV_KEYS_DIR=         # local dev only: dir of <pubkey>.json driver/bettor keypairs
SOLANA_MINT_AUTHORITY_SECRET_KEY=  # local faucet mint authority (fundLocalWallet)
# After `anchor build`, copy target/idl/clanker5000.json -> sidecar/src/generated/clanker5000.json
# x402 on Solana (exact scheme): paid routes (/task, /pilot, race join) verify an
# SPL-USDC transfer to TREASURY_ADDRESS. Pay via the X-PAYMENT header.

# ---- SNS identity (Solana-native naming, replaces ENS) ----
SNS_RPC_URL=https://api.mainnet-beta.solana.com  # SNS is mainnet-beta
SNS_PARENT_LABEL=roverfleet  # resolves guard.roverfleet.sol / courier.roverfleet.sol
SNS_PARENT=roverfleet        # config.ts default for the robots' .sol subdomains

# ---- Privy Solana custody (TEE server wallets) ----
CUSTODY=local                # set to "privy" to sign in Privy's TEE
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_GUARD=          # wallet id from privy-provision.ts (chain_type=solana)
PRIVY_WALLET_COURIER=
PRIVY_ADDR_GUARD=            # base58 Solana pubkey of the guard Privy wallet
PRIVY_ADDR_COURIER=

# ---- Kora gasless relayer (fee payer; EIP-3009 replacement) ----
KORA_RPC_URL=                # Solana Foundation Kora node JSON-RPC (optional)
KORA_API_KEY=                # optional bearer key

# ---- ClawPump (agent token launchpad on Solana / pump.fun) ----
CLAWPUMP_API_URL=https://clawpump.tech/api
CLAWPUMP_API_KEY=            # agent key from the ClawPump dashboard (login-walled)
CLAWPUMP_AGENT_ID=           # your registered ClawPump agent id
CLAWPUMP_DEFAULT_IMAGE=      # optional image URL for launched tokens

# ---- other services ----
GEMINI_API_KEY=              # race-finish verification (vision)
WORLD_RP_ID=                 # rp_... (NOT app_...) — World ID off-chain verifier
WORLD_SIGNING_KEY=
NEXT_PUBLIC_WORLD_APP_ID=    # app_...

# ---- robot-side (set on each Jetson) ----
ROBOT_ROLE=guard             # or courier
PEER_ROBOT_URL=              # the other robot's http://...:8000
SIDECAR_URL=ws://<laptop-ip>:4021
GEOFENCE_ODO=4000
# GIBBER_NETWORK_ONLY=1      # uncomment if venue noise kills audio
