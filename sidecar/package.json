{
  "name": "rover-sidecar",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "sim:robot": "tsx src/sim-robot.ts",
    "build:ledger": "esbuild web-src/ledger.ts --bundle --format=esm --outfile=public/ledger.bundle.js --platform=browser --define:global=globalThis",
    "build:pilot": "esbuild web-src/pilot-app.ts --bundle --format=esm --outfile=public/pilot-app.bundle.js --platform=browser --define:global=globalThis"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
    "@ensdomains/ensjs": "^4.2.3",
    "@google-cloud/bigquery": "^7.9.0",
    "@ledgerhq/context-module": "^2.1.0",
    "@ledgerhq/device-management-kit": "^1.6.0",
    "@ledgerhq/device-signer-kit-ethereum": "^1.16.0",
    "@ledgerhq/device-transport-kit-web-hid": "^1.2.3",
    "@privy-io/node": "latest",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "express": "^4.19.0",
    "rxjs": "^7.8.2",
    "viem": "^2.21.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
