{
  "$schema": "https://eips.ethereum.org/assets/eip-7730/erc7730-v1.schema.json",
  "context": {
    "contract": {
      "abi": [
        { "type": "function", "name": "withdraw", "inputs": [
          { "name": "to", "type": "address" },
          { "name": "amount", "type": "uint256" } ] },
        { "type": "function", "name": "setOwner", "inputs": [
          { "name": "newOwner", "type": "address" } ] }
      ],
      "deployments": [
        { "chainId": 5042002, "address": "0x0000000000000000000000000000000000000000" }
      ]
    }
  },
  "metadata": {
    "owner": "Rover Fleet (rover.eth)",
    "info": {
      "legalName": "The Onchain Rover",
      "url": "https://github.com/0xSoftBoi/onchain-rover"
    }
  },
  "display": {
    "definitions": {
      "usdcAmount": {
        "label": "Amount",
        "format": "tokenAmount",
        "params": { "tokenPath": "@.to", "token": {
          "address": "0x3600000000000000000000000000000000000000",
          "decimals": 6, "ticker": "USDC" } }
      }
    },
    "formats": {
      "withdraw(address to, uint256 amount)": {
        "intent": "Withdraw fleet earnings",
        "fields": [
          { "path": "to", "label": "Recipient", "format": "addressName" },
          { "path": "amount", "label": "Amount (USDC)", "format": "tokenAmount",
            "params": { "token": {
              "address": "0x3600000000000000000000000000000000000000",
              "decimals": 6, "ticker": "USDC" } } }
        ],
        "required": ["to", "amount"]
      },
      "setOwner(address newOwner)": {
        "intent": "Transfer treasury control to a new Ledger",
        "fields": [
          { "path": "newOwner", "label": "New owner", "format": "addressName" }
        ],
        "required": ["newOwner"]
      }
    }
  }
}
